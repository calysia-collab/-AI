HOST=127.0.0.1
PORT=4173
NODE_ENV=development
SASHA_PUBLIC_URL=http://127.0.0.1:4173
SASHA_DB_PATH=.data/sasha-workbench.sqlite
SASHA_MASTER_KEY_PATH=.data/master.key

# Production PostgreSQL. When set, SQLite is not used.
# SASHA_DATABASE_URL=postgresql://user:password@host:5432/sasha
SASHA_DATABASE_SSL=verify-full
SASHA_DATABASE_POOL_SIZE=10

# Production: inject a 32-byte base64 or hex key from a secret manager.
# SASHA_MASTER_KEY=
# Production keyring example:
# SASHA_DATA_KEY_ID=2026-06
# SASHA_DATA_KEYS={"2026-05":"OLD_BASE64_KEY","2026-06":"CURRENT_BASE64_KEY"}
SASHA_COOKIE_SECURE=false
SASHA_TRUST_PROXY=false

# Private encrypted attachment storage and malware scanning.
SASHA_ATTACHMENT_DIR=.data/attachments
# SASHA_CLAMD_HOST=127.0.0.1
SASHA_CLAMD_PORT=3310
SASHA_CLAMD_TIMEOUT_MS=10000
# Development only. Production startup rejects this setting.
SASHA_ATTACHMENT_ALLOW_UNSCANNED=false

# Keep direct remote access disabled. Use an HTTPS reverse proxy in production.
SASHA_ALLOW_INSECURE_REMOTE=false

# One-time CLI bootstrap. Keep disabled except during the first account creation.
SASHA_BOOTSTRAP_ENABLED=false
# SASHA_BOOTSTRAP_ORGANIZATION=莎莎保險助理工作台
# SASHA_BOOTSTRAP_DISPLAY_NAME=張經理
# SASHA_BOOTSTRAP_USERNAME=
# SASHA_BOOTSTRAP_PASSWORD=
